</head>
<body>
 <h2>Servlet Request Redirection</h2>
 <form action="RedirectServlet" method="post">
 Enter URL:
 <input type="text" name="location"
placeholder="https://www.google.com">
 <br><br>
 <input type="submit" value="Go">
 </form>
</body>
